# Customer runtime config (pre-filled)
# If service mode is installed, rerun Install-SmartPOS-Service.bat as Administrator after editing this file.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5080

# Keep product suggestion AI off unless needed
AiSuggestions__Enabled=false

# Enable AI chat/insights
AiInsights__Enabled=true
AiInsights__CloudRelayEnabled=true

# Cloud relay base URLs
AiInsights__CloudRelayBaseUrl=https://smartpos-backend-v7yd.onrender.com
Licensing__CloudRelayBaseUrl=https://smartpos-backend-v7yd.onrender.com
