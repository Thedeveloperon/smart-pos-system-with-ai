# Copy this file as client.env in the same folder as Start-SmartPOS.bat.
# Lines starting with # are ignored.

# Optional: use your own port and host for the local server.
ASPNETCORE_URLS=http://127.0.0.1:5080

# Default behavior uses local name-based suggestions (no external API key required).
# For OpenAI-backed suggestions, set:
OPENAI_API_KEY=

# Alternative to OpenAI:
# AiSuggestions__Provider=Custom
# AiSuggestions__CustomEndpointUrl=http://127.0.0.1:8091/v1/suggestions
# AiSuggestions__CustomSuggestionField=suggestion
# AiSuggestions__RequestTimeoutMs=25000
# CUSTOM_AI_API_KEY=
# AiSuggestions__CustomApiKeyHeader=Authorization
# AiSuggestions__CustomApiKeyPrefix=Bearer

# Strongly recommended: set your own JWT secret in production.
# JwtAuth__SecretKey=replace-with-a-long-random-secret
