# Runtime config is stored outside the install folder.
# Current-user mode: %LOCALAPPDATA%\Lanka POS\data\config\client.env
# Windows service mode: %ProgramData%\Lanka POS\config\client.env
# Copy the values you need into that generated client.env file.
# Lines starting with # are ignored.

# Optional: use your own port and host for the local server.
ASPNETCORE_URLS=http://127.0.0.1:5080
Licensing__CloudRelayBaseUrl=https://smartpos-backend-v7yd.onrender.com
# AI Credit Cloud Relay (recommended): route AI insights/chat/wallet to your cloud backend.
# When enabled, local AI insights do not require OPENAI_API_KEY.
AiInsights__Enabled=true
AiInsights__CloudRelayEnabled=true
AiInsights__CloudRelayBaseUrl=https://smartpos-backend-v7yd.onrender.com
# AiInsights__CloudRelayTimeoutSeconds=30
# AiInsights__CloudRelayWalletCacheMaxAgeSeconds=60

# OPENAI_API_KEY is optional when cloud relay is enabled.
# For direct OpenAI-backed local insights, disable cloud relay and set:
OPENAI_API_KEY=
# AiSuggestions__Enabled=true
# AiInsights__Enabled=true
# AiInsights__CloudRelayEnabled=false

# Alternative to OpenAI (non-production only):
# ASPNETCORE_ENVIRONMENT=Development
# AiSuggestions__Provider=Custom
# AiSuggestions__CustomEndpointUrl=http://127.0.0.1:8091/v1/suggestions
# AiSuggestions__CustomSuggestionField=suggestion
# AiSuggestions__RequestTimeoutMs=25000
# CUSTOM_AI_API_KEY=
# AiSuggestions__CustomApiKeyHeader=Authorization
# AiSuggestions__CustomApiKeyPrefix=Bearer

# Set a long random JWT secret for production deployments.
# If omitted, Start-SmartPOS.bat auto-generates SMARTPOS_JWT_SECRET on first run for local use.
# SMARTPOS_JWT_SECRET=replace-with-a-long-random-secret
# JwtAuth__SecretKey=replace-with-a-long-random-secret

# Licensing data-at-rest encryption key (required for activation key generation and token storage).
# If omitted, Start-SmartPOS.bat auto-generates SMARTPOS_LICENSE_DATA_ENCRYPTION_KEY on first run.
# SMARTPOS_LICENSE_DATA_ENCRYPTION_KEY=replace-with-a-long-random-secret
# Licensing__DataEncryptionKey=replace-with-a-long-random-secret

# Licensing token signing private key (required to issue/activate license tokens).
# Recommended: point to a PEM file path (absolute path is safest on Windows).
# If omitted, Lanka POS auto-creates the signing key under the external data root and saves its path.
# SMARTPOS_LICENSE_SIGNING_PRIVATE_KEY_PEM=C:\ProgramData\Lanka POS\keys\license-signing-private-key.pem
