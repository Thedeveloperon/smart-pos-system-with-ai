#
# SmartPOS backup/restore configuration example
# Copy this file to a secure local path (for example: .env.backup.local)
# and load it before running scripts in scripts/backup/.
#

# --- Backup selection ---
# auto | sqlite | postgres
BACKUP_MODE=auto

# Root folder where backup archives are written
BACKUP_ROOT=./backups

# Optional explicit SQLite DB path (used when BACKUP_MODE=sqlite or auto fallback)
# SQLITE_DB_PATH=./services/backend-api/smartpos.db

# SQLite backup source safety guards
# true: require at least one non-system table before backup
SQLITE_REQUIRE_APP_TABLES=true
# true: require PRAGMA integrity_check to pass before backup
SQLITE_REQUIRE_INTEGRITY_CHECK=true

# Optional Postgres connection string (used when BACKUP_MODE=postgres or auto detect)
# POSTGRES_URL=postgresql://user:password@localhost:5432/smartpos

# --- Retention ---
RETENTION_DAILY=30
RETENTION_WEEKLY=12
RETENTION_MONTHLY=12

# --- Encryption ---
ENABLE_ENCRYPTION=false
# BACKUP_ENCRYPTION_PASSPHRASE=change-me

# --- Optional immutable local copy ---
# IMMUTABLE_COPY_DIR=/mnt/backup-immutable

# --- Optional offsite upload ---
# none | aws_s3 | rclone
OFFSITE_UPLOAD=none

# Required when OFFSITE_UPLOAD=aws_s3
# AWS_S3_URI=s3://my-smartpos-backups

# Required when OFFSITE_UPLOAD=rclone
# RCLONE_REMOTE=remote-name:smartpos-backups

# --- Restore smoke test ---
# auto | sqlite | postgres
RESTORE_MODE=auto

# Required when restoring postgres backups
# POSTGRES_RESTORE_URL=postgresql://user:password@localhost:5432/smartpos_restore

# Optional override for metrics output
METRICS_FILE=./backups/metrics/restore_metrics.jsonl
