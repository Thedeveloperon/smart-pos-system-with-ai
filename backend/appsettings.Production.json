{
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=smartpos.db",
    "Postgres": "Host=localhost;Port=5432;Database=smartpos;Username=smartpos;Password=smartpos",
    "Redis": "localhost:6379"
  },
  "JwtAuth": {
    "Issuer": "smartpos-api",
    "Audience": "smartpos-pwa",
    "SecretKey": "smartpos-change-this-production-secret-2026",
    "ExpiryMinutes": 480,
    "CookieName": "smartpos_auth",
    "SecureCookie": false
  },
  "Purchasing": {
    "EnableOcrImport": true,
    "OcrProvider": "basic-text",
    "TesseractCommand": "tesseract",
    "TesseractLanguage": "eng",
    "TesseractPageSegMode": 6,
    "MaxFileSizeBytes": 10485760,
    "MaxPdfPages": 20,
    "OcrTimeoutMs": 8000,
    "OcrRetryCount": 2,
    "OcrCircuitBreakerFailureThreshold": 4,
    "OcrCircuitBreakerOpenSeconds": 45,
    "LowConfidenceThreshold": 0.75,
    "FuzzyMatchThreshold": 0.72,
    "TotalsToleranceAmount": 2.0,
    "UpdateCostPriceOnImport": true
  },
  "AiSuggestions": {
    "Enabled": true,
    "Provider": "Local",
    "ApiBaseUrl": "https://api.openai.com/v1",
    "Model": "gpt-5.4-mini",
    "RequestTimeoutMs": 12000,
    "CustomEndpointUrl": "",
    "CustomApiKeyHeader": "Authorization",
    "CustomApiKeyPrefix": "Bearer",
    "CustomApiKey": "",
    "CustomSuggestionField": "suggestion"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
