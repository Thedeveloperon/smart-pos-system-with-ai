{
  "Database": {
    "Provider": "Postgres"
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=smartpos-dev.db",
    "Postgres": "Host=localhost;Port=5432;Database=smartpos;Username=smartpos;Password=smartpos",
    "Redis": "localhost:6379"
  },
  "JwtAuth": {
    "Issuer": "smartpos-api",
    "Audience": "smartpos-pwa",
    "SecretKey": "smartpos-dev-secret-key-change-before-production-2026",
    "ExpiryMinutes": 480,
    "CookieName": "smartpos_auth",
    "SecureCookie": false
  },
  "AuthSecurity": {
    "RequireMfaForSuperAdmins": true,
    "TotpStepSeconds": 30,
    "TotpAllowedSkewWindows": 1,
    "ImpossibleTravelLookbackMinutes": 30,
    "ConcurrentDeviceWindowMinutes": 15,
    "ConcurrentDeviceThreshold": 3,
    "ConcurrentSourceThreshold": 2
  },
  "Licensing": {
    "DefaultShopCode": "default",
    "DefaultShopName": "Default SmartPOS Shop",
    "DefaultPlan": "trial",
    "GracePeriodDays": 7,
    "TrialPeriodDays": 14,
    "TrialSeatLimit": 3,
    "TokenTtlMinutes": 15,
    "TokenTtlHours": 24,
    "TokenRotationOverlapSeconds": 90,
    "TokenJtiCleanupIntervalSeconds": 300,
    "TokenJtiRetentionHours": 24,
    "OfflineGrantTtlHours": 48,
    "OfflineGrantMaxHours": 72,
    "OfflineMaxCheckoutOperations": 200,
    "OfflineMaxRefundOperations": 40,
    "DisallowInlinePrivateKey": true,
    "SigningPrivateKeyEnvironmentVariable": "SMARTPOS_LICENSE_SIGNING_PRIVATE_KEY_PEM",
    "EncryptSensitiveDataAtRest": true,
    "DataEncryptionKey": "smartpos-license-data-key-change-before-production",
    "RequireDeviceKeyBinding": false,
    "AllowLegacyActivationWithoutDeviceKey": true,
    "DeviceChallengeTtlSeconds": 300,
    "RequireSensitiveActionDeviceProof": false,
    "SensitiveActionProtectedPathPrefixes": [ "/api/checkout", "/api/refunds", "/api/admin" ],
    "SensitiveActionNonceTtlSeconds": 120,
    "SensitiveActionTimestampToleranceSeconds": 300,
    "TokenCookieEnabled": true,
    "TokenCookieName": "smartpos_license",
    "TokenCookieSecure": false,
    "TokenCookieSameSite": "Lax",
    "TokenCookiePath": "/",
    "AccessSuccessPageBaseUrl": "/license/success",
    "AccessDeliveryEmailEnabled": false,
    "AccessDeliveryFromEmail": "noreply@smartpos.local",
    "AccessDeliveryFromName": "SmartPOS Licensing",
    "AccessDeliverySmtpHost": "",
    "AccessDeliverySmtpPort": 587,
    "AccessDeliverySmtpEnableSsl": true,
    "AccessDeliverySmtpUsername": "",
    "AccessDeliverySmtpPasswordEnvironmentVariable": "SMARTPOS_ACCESS_DELIVERY_SMTP_PASSWORD",
    "AccessDeliverySmtpPassword": "",
    "RequireSecondApprovalForHighValuePayments": true,
    "HighValuePaymentSecondApprovalThreshold": 50000,
    "RequireStepUpApprovalForHighRiskAdminActions": true,
    "HighRiskGraceExtensionDaysThreshold": 7,
    "HighRiskMassRevokeThreshold": 3,
    "EmergencyCommandEnvelopeTtlSeconds": 120,
    "EmergencyCommandSigningSecretEnvironmentVariable": "SMARTPOS_EMERGENCY_COMMAND_SIGNING_SECRET",
    "EmergencyCommandSigningSecret": "",
    "BankReconciliationMismatchToleranceAmount": 1,
    "BillingReconciliationEnabled": true,
    "BillingReconciliationIntervalSeconds": 900,
    "BillingReconciliationPeriodEndGraceHours": 24,
    "BillingReconciliationWebhookFailureLookbackHours": 72,
    "BillingReconciliationTake": 100,
    "BillingReconciliationWebhookFailureTake": 50,
    "SigningPrivateKeyPem": "",
    "VerificationPublicKeyPem": "-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA7UGqa3KKgiOaGj1YlQlO\nnYPYf3Mafy6hQV65jJLEaN2vB6d5RrhPmLXSVh9syxzbS/gIsrM6mQE+Vf0xsIN4\nSxw2Z+vwp3BZp5cJKShYplZQRavNlg73sNSAcVW0+DsgodUScmNWP/R7MrvjsyB7\n6V8vDj7ITnpL29wWmflMP2YVWVr/27ienBxAsuCHL0EzYeSHX3uVa1bGAb33VCx8\nw/Zq3rHpjPEeAzlos2ECLZk+H6I8BoUWEYkcTizSqPYiHrst/rExJRlETU6hur0O\nm9r1dz+b0buIG9K2fZEeXV00BD/F3mPTMV61eu648ezI6tc3DWL9SYIu5kGMxZST\nuQIDAQAB\n-----END PUBLIC KEY-----",
    "SigningKeyId": "smartpos-k1",
    "ActiveSigningKeyId": "smartpos-k1",
    "SigningKeys": [],
    "EnforceProtectedRoutes": true,
    "SuspendedBlockedPathPrefixes": [ "/api/checkout", "/api/refunds" ],
    "Plans": [
      {
        "Code": "trial",
        "SeatLimit": 3,
        "FeatureFlags": [ "checkout", "refunds", "reports-basic", "offline-grace" ]
      },
      {
        "Code": "starter",
        "SeatLimit": 2,
        "FeatureFlags": [ "checkout", "refunds", "reports-basic" ]
      },
      {
        "Code": "growth",
        "SeatLimit": 5,
        "FeatureFlags": [ "checkout", "refunds", "reports-advanced", "supplier-import" ]
      },
      {
        "Code": "pro",
        "SeatLimit": 10,
        "FeatureFlags": [ "checkout", "refunds", "reports-advanced", "supplier-import", "multi-device" ]
      }
    ],
    "WebhookSecurity": {
      "RequireSignature": true,
      "SigningSecret": "smartpos-billing-webhook-secret-change-before-production",
      "SignatureHeaderName": "Stripe-Signature",
      "SignatureScheme": "v1",
      "TimestampToleranceSeconds": 300
    },
    "Alerts": {
      "Enabled": true,
      "EvaluationIntervalSeconds": 30,
      "WindowMinutes": 10,
      "CooldownMinutes": 10,
      "LicenseValidationSpikeThreshold": 20,
      "WebhookFailureThreshold": 5,
      "SecurityAnomalyThreshold": 8
    }
  },
  "Purchasing": {
    "EnableOcrImport": true,
    "OcrProvider": "basic-text",
    "TesseractCommand": "tesseract",
    "TesseractLanguage": "eng",
    "TesseractPageSegMode": 6,
    "MaxFileSizeBytes": 10485760,
    "MaxPdfPages": 20,
    "OcrTimeoutMs": 8000,
    "OcrRetryCount": 2,
    "OcrCircuitBreakerFailureThreshold": 4,
    "OcrCircuitBreakerOpenSeconds": 45,
    "LowConfidenceThreshold": 0.75,
    "FuzzyMatchThreshold": 0.72,
    "TotalsToleranceAmount": 2.0,
    "UpdateCostPriceOnImport": true
  },
  "AiSuggestions": {
    "Enabled": true,
    "Provider": "Local",
    "ApiBaseUrl": "https://api.openai.com/v1",
    "Model": "gpt-5.4-mini",
    "RequestTimeoutMs": 12000,
    "CustomEndpointUrl": "",
    "CustomApiKeyHeader": "Authorization",
    "CustomApiKeyPrefix": "Bearer",
    "CustomApiKey": "",
    "CustomSuggestionField": "suggestion"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
